<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gv_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/gv_purple"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/back_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="@color/gv_white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detail_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Descripción"
                android:textColor="@color/gv_white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/menu_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⋮"
                android:textColor="@color/gv_white"
                android:textSize="26sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/product_image"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:scaleType="centerCrop"
                android:background="@color/gv_light_purple"
                android:contentDescription="Imagen del videojuego" />

            <TextView
                android:id="@+id/product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Baldur's Gate 3"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_genre_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="GÉNERO"
                android:textColor="@color/gv_purple"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_genre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RPG"
                android:textColor="@color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/product_platform_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="PLATAFORMA"
                android:textColor="@color/gv_purple"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_platform"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PC, PlayStation 5, Xbox Series X|S"
                android:textColor="@color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/product_year_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="AÑO DE LANZAMIENTO"
                android:textColor="@color/gv_purple"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2023"
                android:textColor="@color/black"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/product_developer_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="DESARROLLADORA"
                android:textColor="@color/gv_purple"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_developer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Larian Studios"
                android:textColor="@color/black"
                android:textSize="13sp" />


            <TextView
                android:id="@+id/product_likes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="♥ 0"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="DESCRIPCIÓN"
                android:textColor="@color/gv_purple"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Descripción del videojuego"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>