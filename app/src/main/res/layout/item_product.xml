<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/product_item_container"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:layout_marginBottom="16dp"
    android:orientation="vertical"
    android:background="@drawable/bg_game_card"
    android:elevation="4dp">

    <ImageView
        android:id="@+id/product_image"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:scaleType="centerCrop"
        android:background="@color/gv_light_purple"
        android:contentDescription="Imagen del videojuego" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/product_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Baldur's Gate 3"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/product_genre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RPG"
                android:textColor="@color/gv_purple"
                android:textSize="12sp"
                android:textStyle="italic" />

        </LinearLayout>

        <TextView
            android:id="@+id/product_likes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♥︎ 0"
            android:textColor="@color/gv_text_gray"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>